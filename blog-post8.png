name: Publish scheduled blog posts

on:
  schedule:
    # Tuesdays 15:00 UTC = 8:00 AM Pacific during daylight time (Mar-Nov).
    # If posts ever run into Nov-Mar (PST), this fires at 7:00 AM Pacific,
    # which is still fine for a morning publish.
    - cron: '0 15 * * 2'
  workflow_dispatch: {}

permissions:
  contents: write

jobs:
  publish:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Publish due posts
        run: python3 scripts/publish.py

      - name: Commit and push if anything changed
        run: |
          if [[ -n "$(git status --porcelain)" ]]; then
            git config user.name "blog-publisher"
            git config user.email "github-actions[bot]@users.noreply.github.com"
            git add -A
            git commit -m "Publish scheduled blog post(s) — $(date -u +%Y-%m-%d)"
            git push
          else
            echo "Nothing to publish this week."
          fi

      # If the site does NOT auto-deploy from pushes to this branch
      # (i.e. you deploy manually with wrangler), uncomment this step and
      # add CLOUDFLARE_API_TOKEN + CLOUDFLARE_ACCOUNT_ID as repo secrets.
      #
      # - name: Deploy to Cloudflare
      #   run: npx wrangler deploy   # or: npx wrangler pages deploy .
      #   env:
      #     CLOUDFLARE_API_TOKEN: ${{ secrets.CLOUDFLARE_API_TOKEN }}
      #     CLOUDFLARE_ACCOUNT_ID: ${{ secrets.CLOUDFLARE_ACCOUNT_ID }}
